# Your wallet address - this is your builder address
# Change this to your two-wallet setup address when ready to go live
NEXT_PUBLIC_BUILDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Your referral code from Hyperliquid
# Get it at app.hyperliquid.xyz → Settings → Referrals
NEXT_PUBLIC_REFERRAL_CODE=YOURCODE

# Builder fee in tenths of a basis point
# 3 = 0.03% (recommended starting point)
# 10 = 0.1% (max for perps)
NEXT_PUBLIC_BUILDER_FEE=3

# App name shown in the UI
NEXT_PUBLIC_APP_NAME=Coinbroo

# Hyperliquid network: mainnet or testnet
NEXT_PUBLIC_HL_NETWORK=mainnet
